#!/usr/bin/env node

const fs = require('fs');
const path = require('path');
const os = require('os');
const { spawn, execSync } = require('child_process');

// 1. BYPASS CORPORATE SSL INTERCEPTION
process.env.NODE_TLS_REJECT_UNAUTHORIZED = '0';

// 2. BULLETPROOF WINDOWS TEMP PATH RESOLUTION
const localAppData = process.env.LOCALAPPDATA || path.join(process.env.USERPROFILE || 'C:\\Users\\Default', 'AppData', 'Local');
const logFile = path.join(localAppData, 'Temp', 'opencode-automation.log');

function writeLog(message) {
    const timestamp = new Date().toISOString();
    const logLine = `[${timestamp}] ${message}\n`;
    try {
        fs.appendFileSync(logFile, logLine);
    } catch (e) {
        try {
            const fallbackPath = path.join(process.cwd(), '.opencode');
            if (!fs.existsSync(fallbackPath)) fs.mkdirSync(fallbackPath, { recursive: true });
            fs.appendFileSync(path.join(fallbackPath, 'automation-fallback.log'), logLine);
        } catch (fallbackError) {}
    }
}

// 1. Check if this is a branch switch (1)
const isBranchSwitch = process.argv === '1';
if (!isBranchSwitch && process.argv!== 'run-analysis') {
    process.exit(0);
}

// 2. Synchronous Idempotency Check & Detachment
if (process.argv!== 'run-analysis') {
    try {
        const branchName = execSync('git symbolic-ref --short HEAD', { encoding: 'utf8', stdio: 'pipe' }).trim();
        const jiraMatch = branchName.match(/[A-Z]+-[0-9]+/);

        if (!jiraMatch) process.exit(0); 
        
        const jiraKey = jiraMatch;
        const reportPath = path.join('docs', 'analysis', `${jiraKey}-blueprint.md`);
        
        if (fs.existsSync(reportPath)) {
            writeLog(` Branch ${branchName} checked out. Blueprint already exists. Skipping.`);
            process.exit(0);
        }

        writeLog(` Branch ${branchName} checked out. Spawning detached background worker...`);

        const child = spawn(process.execPath, [__filename, 'run-analysis', branchName, jiraKey], {
            detached: true,
            stdio: 'ignore',
            windowsHide: true 
        });
        
        child.unref(); 
        process.exit(0); 
    } catch (e) {
        process.exit(0); 
    }
}

// 3. Asynchronous Background Worker via HTTP API
async function run() {
    const [,, , branchName, jiraKey] = process.argv;
    writeLog(`[${jiraKey}] Worker initialized for branch: ${branchName}`);

    const corpJiraToken = process.env.CORPORATE_JIRA_TOKEN;
    const reqDir = path.join('.opencode', 'requirements');
    const reqFile = path.join(reqDir, `${jiraKey}.md`);
    const outputDir = path.join('docs', 'analysis');
    const outputFile = path.join(outputDir, `${jiraKey}-blueprint.md`);

    try {
        fs.mkdirSync(reqDir, { recursive: true });
        fs.mkdirSync(outputDir, { recursive: true });

        // 3a. Fetch requirement text and custom fields from Jira
        if (!fs.existsSync(reqFile)) {
            writeLog(`[${jiraKey}] Requesting ticket details from Jira API...`);
            const res = await fetch(`https://your-company.atlassian.net/rest/api/3/issue/${jiraKey}`, {
                headers: { 'Authorization': `Bearer ${corpJiraToken}` }
            });
            
            if (!res.ok) {
                writeLog(`[${jiraKey}] ERROR: Jira API failed with status ${res.status}`);
                return;
            }
            
            const data = await res.json();
            const summary = data.fields?.summary || '';
            const desc = data.fields?.description || '';
            let omrDesc = data.fields?.customfield_14724 || '';
            if (typeof omrDesc === 'object') omrDesc = JSON.stringify(omrDesc);

            const content = `# ${jiraKey}: ${summary}\n\n## Description\n${desc}\n\n## OMR Description\n${omrDesc}`;
            fs.writeFileSync(reqFile, content);
        }

        // 3b. Configure MCP, Permissions, and the Custom Architect Agent
        const mcpConfig = {
            default_agent: "architect", // Forces the HTTP session to use our custom agent
            permission: { "*": "allow" },
            agent: {
                "architect": {
                    "mode": "primary",
                    "model": "llm-cib/GPT_OSS_120B_MODEL_ID_HERE", // Replace with your model ID
                    "prompt": "You are a Principal Systems Architect. Your audience is HUMAN software engineers. You must do the deep analysis yourself. DO NOT delegate.\n\nStep 1: Read the requirement details.\nStep 2: Use the 'depwire_get_architecture_summary' and 'depwire_get_file_context' MCP tools to map the entry points, business logic, and data models deterministically.\nStep 3: Use the native 'ls' tool recursively to locate the 'hubs' directory and find.sql scripts inside 'hubs/*/sql'. Use the 'read' tool to inspect them.\nStep 4: Output the complete, highly detailed Markdown blueprint directly as your final text response. Do not use write tools.",
                    "tools": {
                        "task": false, "write": false, "edit": false, "apply_patch": false, "bash": false,
                        "glob": false, "grep": false, "depwire_get_health_score": false, "depwire_update_project_docs": false
                    }
                }
            },
            mcp: {
                depwire: {
                    type: "local",
                    command: process.platform === "win32"? ["cmd.exe", "/c", "depwire.cmd", "mcp"] : ["depwire", "mcp"],
                    enabled: true
                }
            }
        };

        const prompt = `Please analyze the requirement located at '${reqFile}'. Map the codebase using your tools, and output the final human-readable blueprint as your final text response.`;

        // 3c. Spawn the Headless OpenCode HTTP Server
        const serverPort = 8095; // Custom port to avoid collisions
        const repoRoot = process.cwd(); 
        writeLog(`[${jiraKey}] Spawning OpenCode HTTP Server on port ${serverPort}...`);
        
        const serverProcess = spawn('opencode.cmd',, { 
            cwd: repoRoot,
            windowsHide: true,
            shell: true, 
            env: {
               ...process.env,
                OPENCODE_CONFIG_CONTENT: JSON.stringify(mcpConfig),
                OPENCODE_DISABLE_MODELS_FETCH: 'true',
                OPENCODE_DISABLE_DEFAULT_PLUGINS: 'true',
                NODE_TLS_REJECT_UNAUTHORIZED: '0'
            }
        });

        // 3d. Poll the server until it is ready to accept HTTP requests
        let serverReady = false;
        for (let i = 0; i < 20; i++) {
            try {
                const healthRes = await fetch(`http://127.0.0.1:${serverPort}/global/health`);
                if (healthRes.ok) {
                    serverReady = true;
                    break;
                }
            } catch (e) {
                // Wait 1 second before retrying
                await new Promise(r => setTimeout(r, 1000));
            }
        }

        if (!serverReady) {
            serverProcess.kill();
            throw new Error("OpenCode HTTP Server failed to start or timed out.");
        }
        writeLog(`[${jiraKey}] Server is online. Initiating REST API workflow...`);

        // 3e. Create a new session via REST API
        const sessionRes = await fetch(`http://127.0.0.1:${serverPort}/session`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ title: `Analysis for ${jiraKey}` })
        });
        const sessionData = await sessionRes.json();
        const sessionId = sessionData.id;

        // 3f. Send the prompt and wait synchronously for the AI to complete its task
        writeLog(`[${jiraKey}] Sending prompt to session ${sessionId}. Awaiting AI analysis...`);
        const messageRes = await fetch(`http://127.0.0.1:${serverPort}/session/${sessionId}/message`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                parts: [{ type: "text", text: prompt }]
            })
        });
        
        const messageData = await messageRes.json();
        
        // 3g. Extract the final markdown response from the JSON payload
        let blueprintContent = '';
        if (messageData && messageData.parts) {
            blueprintContent = messageData.parts
               .filter(p => p.type === 'text')
               .map(p => p.text)
               .join('\n');
        }

        // 3h. Save the file and clean up
        if (blueprintContent.trim().length > 0) {
            fs.writeFileSync(outputFile, blueprintContent);
            writeLog(`[${jiraKey}] Successfully wrote blueprint file to: ${outputFile}`);
            
            if (process.platform === 'win32') {
                spawn('powershell',::Show('Architectural blueprint for ${jiraKey} generated successfully!','OpenCode Automation')}`], { windowsHide: true });
            }
        } else {
            writeLog(`[${jiraKey}] Warning: No blueprint content was returned from the API.`);
        }

        // Gracefully kill the background server now that the job is done
        serverProcess.kill();
        writeLog(`[${jiraKey}] Background server terminated. Job complete.`);

    } catch (err) {
        writeLog(`[${jiraKey}] FATAL BACKGROUND ERROR: ${err.message}\n${err.stack}`);
    }
}

run();
