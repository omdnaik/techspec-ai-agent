#!/usr/bin/env node

const fs = require('fs');
const path = require('path');
const os = require('os');
const { spawn, execSync } = require('child_process');

// Define the log file path dynamically to the Windows TMP directory
const logFile = path.join(os.tmpdir(), 'opencode-automation.log');

function writeLog(message) {
    try {
        const timestamp = new Date().toISOString();
        fs.appendFileSync(logFile, `[${timestamp}] ${message}\n`);
    } catch (e) {
        // Failsafe to ensure logging failures don't crash the pipeline
    }
}
const { execSync } = require('child_process');

function safelyTerminateZombieNodes() {
  const currentPid = String(process.pid); // 🛡️ Get YOUR active script's process ID
  console.log(`ℹ️ Current Active Process ID: ${currentPid}`);
  console.log("🔍 Scanning for orphaned background Node processes...");
  
  try {
    // Fetch the Command Line execution string and Process ID of all node tasks
    const rawOutput = execSync('wmic process where "name=\'node.exe\'" get CommandLine,ProcessId /FORMAT:CSV', { encoding: 'utf-8' });
    const lines = rawOutput.trim().split('\r\n');
    const zombiesToKill = [];

    lines.forEach(line => {
      // CSV format layout: ComputerName,CommandLine,ProcessId
      if (line && (line.includes('opencode') || line.includes('depwire') || line.includes('mcp-server') || line.includes('@modelcontextprotocol'))) {
        const parts = line.split(',');
        const pid = parts[parts.length - 1].trim(); 
        const cmdLine = parts.slice(1, parts.length - 1).join(',').replace(/"/g, '');

        // 🛡️ CRITICAL EXCLUSION: Never target yourself or you'll drop the execution mid-flight
        if (pid && pid !== currentPid) {
          zombiesToKill.push({ pid, command: cmdLine });
        }
      }
    });

    if (zombiesToKill.length > 0) {
      console.log(`⚠️ Detected ${zombiesToKill.length} orphaned background OpenCode/MCP sub-processes. Terminating safely...`);
      
      zombiesToKill.forEach(zombie => {
        try {
          // Surgically execute taskkill ONLY on the leaked sub-processes
          execSync(`taskkill /F /PID ${zombie.pid}`, { stdio: 'ignore' });
          console.log(`  └── 💥 Terminated Zombie PID ${zombie.pid} -> ${zombie.command.substring(0, 60)}...`);
        } catch (e) {
          // Handle cases where a process died naturally between the scan and the kill command
        }
      });
      console.log("✨ All resource-locking zombie nodes cleared.");
    } else {
      console.log("✅ Clear: No leaked resource locks detected.");
    }
  } catch (error) {
    console.log("✅ Clear: No matching background node processes detected.");
  }
}

// Run the safe cleanup gate right before spawning your main OpenCode workflow
safelyTerminateZombieNodes();

// 1. Check if this is a branch switch (1) or a single file checkout (0)
const isBranchSwitch = process.argv[4] === '1';
if (!isBranchSwitch && process.argv[2] !== 'run-analysis') {
    process.exit(0);
}
// 🧹 CRITICAL FIX: The MCP Janitor Phase
// Forcefully clear out any leaked zombie processes from previous crashes/runs
console.log("🧹 Clearing lingering background MCP channels...");
try {
  // We use taskkill. Ignore errors if no matching zombie processes exist
  execSync('taskkill /F /IM depwire.exe 2>nul', { stdio: 'ignore' });
  execSync('taskkill /F /IM depwire-cli.exe 2>nul', { stdio: 'ignore' });
} catch (e) {
  // Silent catch
}
// 2. Synchronous Idempotency Check
if (process.argv[2] !== 'run-analysis') {
    try {
        const branchName = execSync('git symbolic-ref --short HEAD', { encoding: 'utf8', stdio: 'pipe' }).trim();
        const jiraMatch = branchName.match(/[A-Z]+-[0-9]+/);

        if (!jiraMatch) process.exit(0); 
        
        const jiraKey = jiraMatch[0];
        const reportPath = path.join('docs', 'analysis', `${jiraKey}-blueprint.md`);
        
        if (fs.existsSync(reportPath)) {
            writeLog(`[Trigger] Branch ${branchName} checked out. Blueprint already exists. Skipping.`);
            process.exit(0);
        }

        writeLog(`[Trigger] Branch ${branchName} checked out. Spawning detached background worker...`);

        // Spawn detached background process to prevent terminal blocking
        const child = spawn(process.execPath, [__filename, 'run-analysis', branchName, jiraKey], {
            detached: true,
            stdio: 'ignore',
            windowsHide: true 
        });
        
        child.unref(); 
        process.exit(0); // Return control to the developer instantly
    } catch (e) {
        process.exit(0); 
    }
}

// 3. Asynchronous Background Worker
async function run() {
    const [,, , branchName, jiraKey] = process.argv;
    writeLog(`[${jiraKey}] Worker initialized for branch: ${branchName}`);

    const corpJiraToken = process.env.CORPORATE_JIRA_TOKEN;
    const reqDir = path.join('.opencode', 'requirements');
    const reqFile = path.join(reqDir, `${jiraKey}.md`);
    const outputDir = path.join('docs', 'analysis');
    const outputFile = path.join(outputDir, `${jiraKey}-blueprint.md`);

    try {
        fs.mkdirSync(reqDir, { recursive: true });
        fs.mkdirSync(outputDir, { recursive: true });

        // 3a. Fetch requirement text and custom fields from Jira
        if (!fs.existsSync(reqFile)) {
            writeLog(`[${jiraKey}] Requesting ticket details from Jira API...`);
            const res = await fetch(`https://your-company.atlassian.net/rest/api/3/issue/${jiraKey}`, {
                headers: { 'Authorization': `Bearer ${corpJiraToken}` }
            });
            
            if (!res.ok) {
                writeLog(`[${jiraKey}] ERROR: Jira API failed with status ${res.status} - ${res.statusText}`);
                return;
            }
            
            const data = await res.json();
            const summary = data.fields?.summary || '';
            const desc = data.fields?.description || '';
            
            let omrDesc = data.fields?.customfield_14724 || '';
            if (typeof omrDesc === 'object') omrDesc = JSON.stringify(omrDesc);

            const content = `# ${jiraKey}: ${summary}\n\n## Description\n${desc}\n\n## OMR Description\n${omrDesc}`;
            fs.writeFileSync(reqFile, content);
            writeLog(`[${jiraKey}] Successfully saved Jira requirements locally.`);
        } else {
            writeLog(`[${jiraKey}] Local requirement file already exists. Using cache.`);
        }

        // 3b. Dynamically inject the MCP server config into OpenCode at runtime
        const mcpConfig = {
            mcp: {
                depwire: {
                    type: "local",
                    command: process.platform === "win32" ? ["npx.cmd", "-y", "depwire-cli", "mcp"] : ["npx", "-y", "depwire-cli", "mcp"],
                    enabled: true
                }
            }
        };

        const prompt = `You are an Enterprise Systems Architect. Your task is to analyze the requirement for Jira ticket ${jiraKey} and generate a comprehensive blueprint of required code changes.

Please execute the following steps sequentially:
1. Requirement Extraction: Read the requirement details and OMR description from '${reqFile}'.
2. Architecture Mapping: Use the local 'depwire' MCP server tools to trace the current dependency graph. Focus on identifying the core application entry points, business logic handlers, and data persistence models. Do not guess dependencies; rely strictly on Depwire's deterministic AST graph.
3. Database Script Analysis: Use your native 'glob' and 'read' tools to locate and inspect any .sql scripts specifically located within the 'hubs/*/sql' directories. Cross-reference these SQL files with the application's data access layer.
4. Synthesis: Generate a detailed, layer-by-layer markdown blueprint detailing the exact source files to be modified, the SQL changes required, and a structural impact analysis. Output the final blueprint using your 'write' tool to the file '${outputFile}'.`;

        // 3d. Invoke OpenCode CLI headlessly with explicit directory locking
        const repoRoot = process.cwd(); 
        const opencodeCmd = process.platform === 'win32' ? 'opencode.cmd' : 'opencode';
        
        writeLog(`[${jiraKey}] Launching OpenCode agent with directory locked to: ${repoRoot}`);
        
        const agent = spawn(opencodeCmd, [
            'run',
            '--agent', 'plan',
            '--dir', repoRoot,
            prompt
        ], { 
            windowsHide: true,
            env: {
                ...process.env,
                OPENCODE_CONFIG_CONTENT: JSON.stringify(mcpConfig)
            }
        });

        // 3e. Capture the standard output/error of the AI execution into our log file
        agent.stdout.on('data', (data) => {
            writeLog(`[${jiraKey}] OpenCode: ${data.toString().trim()}`);
        });

        agent.stderr.on('data', (data) => {
            writeLog(`[${jiraKey}] OpenCode ERR: ${data.toString().trim()}`);
        });

        // Wait for the agent to finish execution
        await new Promise((resolve) => {
            agent.on('exit', (code) => {
                writeLog(`[${jiraKey}] OpenCode agent exited with status code: ${code}`);
                resolve(code);
            });
            agent.on('error', (err) => {
                writeLog(`[${jiraKey}] OpenCode spawn error: ${err.message}`);
                resolve(1);
            });
        });

        // 3f. Trigger Windows desktop notification
        if (process.platform === 'win32') {
            writeLog(`[${jiraKey}] Triggering Windows native notification.`);
            spawn('powershell', ['-Command', `& {Add-Type -AssemblyName PresentationFramework; [System.Windows.MessageBox]::Show('Architectural blueprint for ${jiraKey} generated successfully!','OpenCode Automation')}`], { windowsHide: true });
        }
        
        writeLog(`[${jiraKey}] Automation sequence completed successfully.`);
        
    } catch (err) {
        writeLog(`[${jiraKey}] FATAL BACKGROUND ERROR: ${err.message}\n${err.stack}`);
    }
}

run();
